rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /savedJobs/{savedJobId} {
      function isValidSavedJob(data) {
        return data.userId == request.auth.uid &&
               data.jobId is string &&
               data.title is string &&
               data.company is string &&
               data.locations is string &&
               data.url is string &&
               data.site is string &&
               data.description is string &&
               data.savedAt is string;
      }

      allow create: if isSignedIn() && isValidSavedJob(request.resource.data);
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /cvs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isSignedIn() && 'email' in request.auth.token && request.auth.token.email == 'coppolek@gmail.com';
    }
  }
}
